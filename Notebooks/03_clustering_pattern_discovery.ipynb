    ").round(2)\n",
    "\n",
    "print('Cluster profiles (mean values):')\n",
    "print(cluster_profiles[CLUSTER_FEATURES].to_string())\n",
    "print('\\nGovernorate memberships:')\n",
    "for c, row in cluster_profiles.iterrows():\n",
    "    print(f'  Cluster {c}: {row[\"governorate\"]}')"
